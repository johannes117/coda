{
  "name": "coda",
  "version": "0.1.0",
  "packageManager": "bun",
  "description": "coda - Your AI Coding Agent",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "coda": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && tsc-alias -p tsconfig.json",
    "start": "bun run dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run --exclude '**/evals/**'",
    "eval": "bun run src/evals/index.ts",
    "evals:seed": "bun run src/evals/seed-dataset.ts",
    "logs:tail": "tail -f ~/.coda/logs/coda.log"
  },
  "dependencies": {
    "@alcalzone/ansi-tokenize": "^0.3.0",
    "@langchain/anthropic": "^1.3.29",
    "@langchain/core": "^1.1.44",
    "@langchain/langgraph": "^1.3.0",
    "@langchain/openai": "^1.4.5",
    "auto-bind": "^5.0.1",
    "bidi-js": "^1.0.3",
    "chalk": "^5.6.2",
    "cli-boxes": "^4.0.1",
    "code-excerpt": "^4.0.0",
    "deepagents": "^1.10.2",
    "dotenv": "^17.2.2",
    "emoji-regex": "^10.6.0",
    "get-east-asian-width": "^1.6.0",
    "indent-string": "^5.0.0",
    "langchain": "^1.4.0",
    "langsmith": "^0.6.3",
    "lodash-es": "^4.18.1",
    "openevals": "^0.1.1",
    "react": "^19.1.0",
    "react-reconciler": "^0.32.0",
    "semver": "^7.8.5",
    "signal-exit": "^4.1.0",
    "stack-utils": "^2.0.6",
    "string-width": "^8.2.1",
    "strip-ansi": "^7.2.0",
    "supports-hyperlinks": "^4.5.0",
    "type-fest": "^5.7.0",
    "usehooks-ts": "^3.1.1",
    "wrap-ansi": "^10.0.0",
    "yargs": "^17.7.2",
    "zod": "^4.0.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20.11.24",
    "@types/react": "^19.1.8",
    "@types/react-reconciler": "^0.33.0",
    "@types/semver": "^7.7.1",
    "@types/stack-utils": "^2.0.3",
    "@types/yargs": "^17.0.32",
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@typescript-eslint/parser": "^8.44.1",
    "eslint": "^9.36.0",
    "eslint-plugin-unicorn": "^61.0.2",
    "jsdom": "^26.1.0",
    "tsc-alias": "^1.8.10",
    "typescript": "^5.3.3",
    "vitest": "^3.1.1"
  },
  "engines": {
    "node": ">=20"
  }
}
